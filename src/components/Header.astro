---
import { site } from "../data/site";

const links = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/weddings", label: "Weddings" },
  { href: "/contact", label: "Contact" },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="sticky top-0 z-50 bg-soot-950/95 backdrop-blur supports-[backdrop-filter]:bg-soot-950/80 border-b border-white/10">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex h-16 items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-2.5 group">
        <span class="grid h-9 w-9 place-items-center rounded-lg bg-ember-500 text-soot-950 shadow-lg shadow-ember-900/30">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 21V8l4-3 4 3v3h6v10" stroke="currentColor" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
            <path d="M9 21v-5h0M16 5c0-1 1-2 2-2s2 1 2 2-1 2-2 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="leading-tight">
          <span class="block font-display text-base font-600 text-cream">O'Connor</span>
          <span class="block text-[10px] uppercase tracking-[0.18em] text-ember-300">Chimney Sweeps</span>
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-1">
        {links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "px-3.5 py-2 rounded-md text-sm font-500 transition-colors",
              isActive(l.href)
                ? "text-ember-300"
                : "text-soot-200 hover:text-cream hover:bg-white/5",
            ]}
          >
            {l.label}
          </a>
        ))}
      </nav>

      <a
        href={site.phoneHref}
        class="inline-flex items-center gap-2 rounded-full bg-ember-500 px-4 py-2 text-sm font-600 text-soot-950 shadow-lg shadow-ember-900/30 transition hover:bg-ember-400"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1L6.6 10.8Z"/>
        </svg>
        <span class="hidden sm:inline">{site.phone}</span>
        <span class="sm:hidden">Call</span>
      </a>
    </div>
  </div>
</header>
