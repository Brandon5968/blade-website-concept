---
import { site } from "../data/site";
interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = "Book a sweep or ask for a quote",
  sub = "Give us a call and talk to the same crew that has worked across Victoria for over 30 years. We will give you a clear price and a time that suits.",
} = Astro.props;
---

<section class="bg-paper">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
    <div class="relative overflow-hidden rounded-2xl bg-green-700 px-6 py-12 sm:px-12 sm:py-14">
      <div class="absolute -right-12 -top-12 h-48 w-48 rounded-full bg-green-400/20 blur-2xl"></div>
      <div class="relative flex flex-col items-start gap-6 md:flex-row md:items-center md:justify-between">
        <div class="max-w-xl">
          <h2 class="font-display text-3xl font-700 text-white sm:text-4xl">{heading}</h2>
          <p class="mt-3 text-green-50/90">{sub}</p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href={site.phoneHref} class="inline-flex items-center gap-2 rounded-md bg-white px-6 py-3 font-700 text-green-800 shadow-sm transition hover:bg-green-50">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1L6.6 10.8Z"/></svg>
            {site.phone}
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 rounded-md border border-white/50 px-6 py-3 font-700 text-white transition hover:bg-white/10">
            Request a quote
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
