---
interface Props {
  before: string;
  after: string;
  beforeAlt: string;
  afterAlt: string;
  caption?: string;
}
const { before, after, beforeAlt, afterAlt, caption } = Astro.props;
---

<figure class="ba" data-ba>
  <div class="ba-stage">
    <!-- AFTER sits underneath as the base layer -->
    <img class="ba-img" src={after} alt={afterAlt} width="949" height="350" loading="lazy" decoding="async" />
    <!-- BEFORE is clipped from the right by the slider position -->
    <div class="ba-before">
      <img class="ba-img" src={before} alt={beforeAlt} width="949" height="350" loading="lazy" decoding="async" />
    </div>

    <span class="ba-tag ba-tag--l">Before</span>
    <span class="ba-tag ba-tag--r">After</span>

    <div class="ba-handle" aria-hidden="true">
      <span class="ba-grip">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 7 4 12l5 5M15 7l5 5-5 5"/></svg>
      </span>
    </div>

    <input class="ba-range" type="range" min="0" max="100" value="50"
      aria-label={`Drag to compare before and after${caption ? ": " + caption : ""}`} />
  </div>
  {caption && <figcaption class="ba-cap">{caption}</figcaption>}
</figure>

<style>
  .ba { margin: 0; }
  .ba-stage {
    position: relative;
    aspect-ratio: 949 / 350;
    overflow: hidden;
    border-radius: 0.75rem;
    background: #0d0c0a;
    --pos: 50%;
    touch-action: none;
  }
  .ba-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
    -webkit-user-drag: none;
  }
  .ba-before {
    position: absolute;
    inset: 0;
    clip-path: inset(0 calc(100% - var(--pos)) 0 0);
  }
  .ba-tag {
    position: absolute;
    top: 0.75rem;
    z-index: 3;
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.7rem;
    color: #fff;
    background: rgba(0, 0, 0, 0.55);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }
  .ba-tag--l { left: 0.75rem; }
  .ba-tag--r { right: 0.75rem; }
  .ba-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--pos);
    width: 0;
    z-index: 4;
    border-left: 3px solid #fff;
    transform: translateX(-1.5px);
    pointer-events: none;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.15);
  }
  .ba-grip {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background: #fff;
    color: var(--color-green-800);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
  }
  .ba-range {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    opacity: 0;
    cursor: ew-resize;
    z-index: 5;
  }
  .ba-cap {
    margin-top: 0.75rem;
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.85rem;
    color: #fff;
  }
</style>

<script>
  function initBeforeAfter() {
    document.querySelectorAll<HTMLElement>("[data-ba]").forEach((fig) => {
      const stage = fig.querySelector<HTMLElement>(".ba-stage");
      const range = fig.querySelector<HTMLInputElement>(".ba-range");
      if (!stage || !range) return;
      const update = () => stage.style.setProperty("--pos", range.value + "%");
      range.addEventListener("input", update);
      update();
    });
  }
  initBeforeAfter();
  document.addEventListener("astro:after-swap", initBeforeAfter);
</script>
