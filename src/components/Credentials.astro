---
// Trust badges. AHHA mark cropped from the official member logo.
const items = [
  {
    title: "AHHA Member",
    sub: "Australian Home Heating Association",
    logo: "/images/ahha-mark.png",
  },
  {
    title: "Confined Spaces Certified",
    sub: "WorkSafe Victoria Code of Practice",
    icon: "M9 12l2 2 4-4M12 3l8 4v5c0 5-3.4 8-8 9-4.6-1-8-4-8-9V7l8-4Z",
  },
  {
    title: "Fully Insured",
    sub: "Safety-trained crews on every job",
    icon: "M20 7 9 18l-5-5",
  },
  {
    title: "Contractors Board On Site",
    sub: "Erected at every work site",
    icon: "M4 5h16v11H4zM9 21h6M12 16v5",
  },
];
---

<section class="bg-paper">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-8">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {items.map((it) => (
        <div class="flex items-center gap-3.5 rounded-xl border border-ink-100 bg-sand px-4 py-3.5">
          {it.logo ? (
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-lg border border-ink-100 bg-white p-1.5">
              <img src={it.logo} alt="Australian Home Heating Association member" width="40" height="40" class="h-full w-full object-contain" loading="lazy" />
            </span>
          ) : (
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-lg bg-green-100 text-green-800">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={it.icon} /></svg>
            </span>
          )}
          <div class="min-w-0">
            <div class="font-display text-sm font-700 uppercase tracking-tight text-ink-900">{it.title}</div>
            <div class="text-xs leading-tight text-ink-500">{it.sub}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
