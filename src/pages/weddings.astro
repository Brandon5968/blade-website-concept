---
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../data/site";

const inclusions = [
  { t: "A costumed sweep", d: "Top hat, tails and brushes. The real thing, not a fancy dress hire." },
  { t: "The lucky greeting", d: "A handshake for the groom and the traditional kiss on the cheek for the bride." },
  { t: "Photos with your guests", d: "Our sweep is happy to pose for those keepsake shots for the album." },
  { t: "A little keepsake", d: "A small token of good luck for the happy couple to take home." },
];
---

<Layout title="Wedding Sweeps" description="Book a traditional good luck chimney sweep for your wedding day. Top hat and tails, the lucky kiss and photos with your guests.">
  <!-- hero -->
  <section class="bg-paper-soft border-b border-ink-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20">
      <div class="max-w-2xl animate-fade-up">
        <span class="inline-flex items-center gap-2 rounded-full border border-green-200 bg-green-50 px-3.5 py-1.5 text-xs font-600 text-green-800">A charming old tradition</span>
        <h1 class="mt-6 font-display text-4xl font-800 uppercase leading-[1.05] tracking-tight text-ink-900 sm:text-5xl">A sweep at your wedding brings <span class="text-green-600">good luck</span></h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-600">
          For centuries a chimney sweep has been a sign of good fortune at a wedding. We will send a
          genuine sweep, in top hat and tails, to shake the groom's hand, kiss the bride and wish your
          day a lifetime of luck.
        </p>
        <a href={site.phoneHref} class="mt-8 inline-flex items-center gap-2 rounded-md bg-green-600 px-6 py-3.5 font-700 text-white shadow-sm transition hover:bg-green-700">
          Enquire about a wedding sweep
        </a>
      </div>
    </div>
  </section>

  <!-- the story -->
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-20 text-center">
    <p class="text-sm font-700 uppercase tracking-[0.16em] text-green-600">The tradition</p>
    <h2 class="mt-3 font-display text-3xl font-800 uppercase tracking-tight text-ink-900 sm:text-4xl">Why a sweep means luck</h2>
    <p class="mt-5 text-lg leading-relaxed text-ink-600">
      The story goes that a sweep once saved a king from a runaway carriage, and from that day sweeps
      were seen as bringers of good luck. Meeting one on your wedding day, or having one shake your hand
      and kiss the bride, is said to bless the marriage with happiness and good fortune. It is a warm
      touch that your guests will remember.
    </p>
  </section>

  <!-- inclusions -->
  <section class="bg-paper-soft border-y border-ink-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-20">
      <div class="max-w-2xl">
        <p class="text-sm font-700 uppercase tracking-[0.16em] text-green-600">What is included</p>
        <h2 class="mt-2 font-display text-3xl font-800 uppercase tracking-tight text-ink-900 sm:text-4xl">Your wedding sweep visit</h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        {inclusions.map((i, idx) => (
          <div class="flex gap-5 rounded-2xl border border-ink-100 bg-paper p-7">
            <span class="font-display text-4xl font-800 text-green-300">{`0${idx + 1}`}</span>
            <div>
              <h3 class="font-display text-xl font-700 text-ink-900">{i.t}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-600">{i.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading="Bring a little luck to your big day" sub="Wedding sweep visits book out fast in peak season, so get in touch early to lock in your date." />
</Layout>
