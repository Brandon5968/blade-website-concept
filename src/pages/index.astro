---
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";
import Credentials from "../components/Credentials.astro";
import Testimonials from "../components/Testimonials.astro";
import BeforeAfter from "../components/BeforeAfter.astro";
import { site } from "../data/site";

const divisions = [
  {
    name: "Industrial",
    area: "Australia-wide",
    img: "/images/work-9.jpg",
    alt: "Industrial stenter and exhaust line in a Victorian factory",
    desc: "Stenters, exhaust systems and process ovenlines cleaned and certified so your plant keeps running and stays compliant. We work with German and European ovenline equipment and tin-plate printing lines.",
    points: ["Exhaust and extraction systems", "Stenter and process ovenlines", "Confined space certified crews"],
  },
  {
    name: "Commercial",
    area: "Victoria-wide",
    img: "/images/work-6.jpg",
    alt: "Commercial wood-fired pizza oven being serviced",
    desc: "Pizza ovens, kitchen canopies and grease flues cleaned to fire safety standard, booked around your trading hours. We run ongoing maintenance programs for hotel groups and hospitality venues.",
    points: ["Kitchen canopy and flue cleaning", "Pizza and bakery ovens", "Maintenance programs available"],
  },
  {
    name: "Domestic",
    area: "Victoria-wide",
    img: "/images/work-2.jpg",
    alt: "Clean domestic flue interior after sweeping",
    desc: "Wood heaters, open fires and flex-duct cleaned without the mess, so your home stays safe through winter. We also handle beehive and possum removal, possum grids, cowls and dampers.",
    points: ["Wood heaters and open fires", "Beehive and possum removal", "Cowl and damper installation"],
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="bg-sand">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-14 sm:py-20">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div class="animate-fade-up">
          <span class="inline-flex items-center gap-2 rounded-full border border-green-200 bg-green-50 px-3.5 py-1.5 text-xs font-600 text-green-800">
            <span class="h-1.5 w-1.5 rounded-full bg-green-400"></span>
            Family-run and Australian since {site.established}
          </span>
          <h1 class="mt-6 font-display text-5xl font-700 uppercase leading-[0.95] tracking-tight text-ink-900 sm:text-6xl">
            Victoria's chimney sweeps for <span class="text-green-700">over 30 years</span>
          </h1>
          <p class="mt-6 max-w-[60ch] text-lg leading-relaxed text-ink-800">
            Michael O'Connor &amp; Son Industries cleans and certifies domestic, commercial and
            industrial flues, ovens and exhaust systems. The same family crew has done this work
            since 1990.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={site.phoneHref} class="inline-flex items-center gap-2 rounded-md bg-green-700 px-6 py-3.5 font-700 text-white shadow-sm transition hover:bg-green-800">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1L6.6 10.8Z"/></svg>
              Call {site.phone}
            </a>
            <a href="/services" class="inline-flex items-center gap-2 rounded-md border border-ink-300 bg-paper px-6 py-3.5 font-700 text-ink-900 transition hover:border-ink-400 hover:bg-ink-50">
              See our services
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <p class="mt-6 text-sm font-600 text-ink-700">
            {site.hours}. {site.emergency}.
          </p>
        </div>

        <div class="relative">
          <div class="overflow-hidden rounded-2xl border border-ink-200 shadow-xl shadow-ink-900/10">
            <img src="/images/work-9.jpg" alt="Industrial exhaust line and stenter cleaned by Michael O'Connor & Son" width="1000" height="750" class="aspect-[4/3] w-full object-cover" loading="eager" />
          </div>
          <div class="absolute -bottom-4 -left-4 hidden rounded-xl bg-green-700 px-5 py-4 text-white shadow-lg sm:block">
            <div class="font-display text-3xl font-700 leading-none">30+ years</div>
            <div class="mt-1 text-xs text-green-100">domestic to industrial</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Credentials />

  <!-- Before / after (the proof) -->
  <section class="bg-ink-900">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-20">
      <div class="max-w-2xl">
        <p class="text-sm font-700 uppercase tracking-[0.16em] text-green-400">See the difference</p>
        <h2 class="mt-2 font-display text-3xl font-700 uppercase tracking-tight text-white sm:text-4xl">Drag to see a flue before and after</h2>
        <p class="mt-4 max-w-[60ch] text-ink-200">
          A clean flue is the whole job. These are real exhaust systems and flues we have cleaned.
          Drag the handle across each photo to see the build-up we clear out.
        </p>
      </div>
      <div class="mt-10 grid gap-8 lg:grid-cols-2">
        <BeforeAfter
          before="/images/ba1-before.jpg"
          after="/images/ba1-after.jpg"
          beforeAlt="Industrial exhaust fan housing caked with debris before cleaning"
          afterAlt="The same exhaust fan housing cleaned and clear"
          caption="Industrial exhaust fan"
        />
        <BeforeAfter
          before="/images/ba2-before.jpg"
          after="/images/ba2-after.jpg"
          beforeAlt="Flue interior coated with soot and creosote before cleaning"
          afterAlt="The same flue swept clean back to bare metal"
          caption="Flue and ductwork"
        />
      </div>
    </div>
  </section>

  <!-- Divisions -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-20">
    <div class="max-w-2xl">
      <p class="text-sm font-700 uppercase tracking-[0.16em] text-green-700">What we do</p>
      <h2 class="mt-2 font-display text-3xl font-700 uppercase tracking-tight text-ink-900 sm:text-4xl">Three divisions, one family crew</h2>
      <p class="mt-4 max-w-[64ch] text-ink-800">
        Domestic and commercial work right across Victoria, and industrial work across Australia.
        Whatever you burn, the same team cleans it, checks it and signs it off.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {divisions.map((d) => (
        <article class="group flex flex-col overflow-hidden rounded-2xl border border-ink-100 bg-paper shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
          <div class="overflow-hidden">
            <img src={d.img} alt={d.alt} width="800" height="534" loading="lazy" class="aspect-[3/2] w-full object-cover transition duration-500 group-hover:scale-105" />
          </div>
          <div class="flex flex-1 flex-col p-7">
            <div class="flex items-center justify-between gap-2">
              <h3 class="font-display text-2xl font-700 uppercase tracking-tight text-ink-900">{d.name}</h3>
              <span class="rounded-full bg-green-100 px-2.5 py-1 text-[11px] font-600 text-green-800">{d.area}</span>
            </div>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-700">{d.desc}</p>
            <ul class="mt-5 space-y-2">
              {d.points.map((p) => (
                <li class="flex items-center gap-2.5 text-sm text-ink-800">
                  <svg class="h-4 w-4 shrink-0 text-green-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                  {p}
                </li>
              ))}
            </ul>
            <a href="/services" class="mt-6 inline-flex items-center gap-1.5 text-sm font-700 text-green-800 transition group-hover:gap-2.5">
              More on {d.name.toLowerCase()}
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Why us -->
  <section class="bg-paper border-y border-ink-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-20">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div class="order-2 grid grid-cols-2 gap-4 lg:order-1">
          <img src="/images/work-7.jpg" alt="Soot and debris cleared from the base of a flue" width="800" height="534" loading="lazy" class="aspect-[3/4] w-full rounded-2xl object-cover" />
          <img src="/images/work-8.jpg" alt="Inside a cleaned industrial exhaust housing" width="800" height="534" loading="lazy" class="mt-8 aspect-[3/4] w-full rounded-2xl object-cover" />
        </div>
        <div class="order-1 lg:order-2">
          <p class="text-sm font-700 uppercase tracking-[0.16em] text-green-700">Why O'Connor</p>
          <h2 class="mt-2 font-display text-3xl font-700 uppercase tracking-tight text-ink-900 sm:text-4xl">Old-school trade, done right</h2>
          <div class="mt-7 space-y-6 max-w-[60ch]">
            <div>
              <h3 class="font-display text-lg font-700 uppercase tracking-tight text-ink-900">Over 30 years on the tools</h3>
              <p class="mt-1.5 text-ink-800">A family business that has cleaned chimneys, kitchens and factory exhaust lines since 1990.</p>
            </div>
            <div>
              <h3 class="font-display text-lg font-700 uppercase tracking-tight text-ink-900">Certified and insured</h3>
              <p class="mt-1.5 text-ink-800">WorkSafe confined space certified, fully insured, and members of the Australian Home Heating Association. A contractors board goes up on every site.</p>
            </div>
            <div>
              <h3 class="font-display text-lg font-700 uppercase tracking-tight text-ink-900">No mess left behind</h3>
              <p class="mt-1.5 text-ink-800">We lay drop sheets, keep the dust contained, and leave your home or kitchen the way we found it.</p>
            </div>
            <div>
              <h3 class="font-display text-lg font-700 uppercase tracking-tight text-ink-900">Here when you need us</h3>
              <p class="mt-1.5 text-ink-800">Open seven days, with a 24 hour emergency line for blocked flues and anything urgent.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Testimonials />

  <CtaBand />
</Layout>
