---
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../data/site";

const stats = [
  { value: site.yearsExperience, label: "Years in business" },
  { value: "3", label: "Service divisions" },
  { value: "7 days", label: "Including weekends" },
  { value: "24 hr", label: "Emergency call-out" },
];

const divisions = [
  {
    name: "Industrial",
    img: "/images/work-9.jpg",
    alt: "Industrial stenter and exhaust line in a Victorian factory",
    desc: "Stenters, exhaust systems and process ductwork cleaned and certified so your plant stays compliant and keeps running.",
    points: ["Exhaust and extraction systems", "Stenter and oven lines", "Confined space certified crews"],
  },
  {
    name: "Commercial",
    img: "/images/work-6.jpg",
    alt: "Commercial wood-fired pizza oven being serviced",
    desc: "Pizza ovens, kitchen canopies and grease flues cleaned to fire safety standard, booked around your trading hours.",
    points: ["Kitchen canopy and flue cleaning", "Pizza and bakery ovens", "Fire safety documentation"],
  },
  {
    name: "Domestic",
    img: "/images/work-2.jpg",
    alt: "Clean domestic flue interior after sweeping",
    desc: "Wood heaters, open fires and flex-duct cleaned without the mess, so your home stays safe through winter.",
    points: ["Wood heaters and open fires", "Flex-duct cleaning", "Clean, tidy service"],
  },
];

const reasons = [
  { title: "Over 30 years on the tools", body: "A family business that has cleaned chimneys, kitchens and factory exhaust lines across Victoria since 1990." },
  { title: "Safety trained and certified", body: "Our crews are WorkSafe confined space certified and fully insured, and we are members of the Australian Home Heating Association." },
  { title: "Tidy work, no mess left behind", body: "We lay drop sheets, keep the dust contained and leave your home or kitchen the way we found it." },
  { title: "Here when you need us", body: "We work seven days a week and run a 24 hour emergency line for blocked flues and anything urgent." },
];

const steps = [
  { n: "1", t: "Call or send an enquiry", d: "Tell us what needs doing, whether it is a home heater, a kitchen canopy or an industrial line. We will give you a clear price." },
  { n: "2", t: "We clean and check", d: "We sweep the system, contain the mess and check your flue, ducting and fittings while we are there." },
  { n: "3", t: "Cleaned and signed off", d: "You get a clean, safe system and the compliance paperwork where it is needed." },
];
---

<Layout>
  <!-- Hero -->
  <section class="bg-paper-soft">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-20">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div class="animate-fade-up">
          <span class="inline-flex items-center gap-2 rounded-full border border-green-200 bg-green-50 px-3.5 py-1.5 text-xs font-600 text-green-800">
            <span class="h-1.5 w-1.5 rounded-full bg-green-400"></span>
            Serving {site.region} since {site.established}
          </span>
          <h1 class="mt-6 font-display text-4xl font-800 uppercase leading-[1.05] tracking-tight text-ink-900 sm:text-5xl">
            Chimney and flue cleaning <span class="text-green-600">done properly</span>
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-600">
            Michael O'Connor & Son Industries has swept Victoria's chimneys, kitchen canopies and
            industrial exhaust systems for more than 30 years. {site.hours}.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={site.phoneHref} class="inline-flex items-center gap-2 rounded-md bg-green-600 px-6 py-3.5 font-700 text-white shadow-sm transition hover:bg-green-700">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1L6.6 10.8Z"/></svg>
              Call {site.phone}
            </a>
            <a href="/services" class="inline-flex items-center gap-2 rounded-md border border-ink-200 bg-paper px-6 py-3.5 font-700 text-ink-800 transition hover:border-ink-300 hover:bg-ink-50">
              See our services
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-ink-600">
            {site.accreditations.map((a) => (
              <span class="inline-flex items-center gap-2">
                <svg class="h-4 w-4 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                {a.split(", ")[0].split(" member")[0]}
              </span>
            ))}
          </div>
        </div>

        <div class="relative">
          <div class="overflow-hidden rounded-2xl border border-ink-100 shadow-xl shadow-ink-900/5">
            <img src="/images/work-9.jpg" alt="Industrial stenter and factory exhaust line cleaned by Michael O'Connor & Son" width="1000" height="368" class="aspect-[5/4] w-full object-cover sm:aspect-[4/3]" loading="eager" />
          </div>
          <div class="absolute -bottom-4 -left-4 hidden rounded-xl bg-green-600 px-5 py-4 text-white shadow-lg sm:block">
            <div class="font-display text-2xl font-800">30+ years</div>
            <div class="text-xs text-green-50">across Victoria</div>
          </div>
        </div>
      </div>
    </div>

    <!-- stat strip -->
    <div class="border-t border-ink-100">
      <div class="mx-auto max-w-6xl grid grid-cols-2 divide-x divide-ink-100 sm:grid-cols-4">
        {stats.map((s) => (
          <div class="px-4 py-6 text-center">
            <div class="font-display text-3xl font-800 text-green-600">{s.value}</div>
            <div class="mt-1 text-xs uppercase tracking-wide text-ink-500">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Divisions -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-20">
    <div class="max-w-2xl">
      <p class="text-sm font-700 uppercase tracking-[0.16em] text-green-600">What we do</p>
      <h2 class="mt-2 font-display text-3xl font-800 uppercase tracking-tight text-ink-900 sm:text-4xl">Three divisions, one trusted crew</h2>
      <p class="mt-4 text-ink-600">From a single wood heater to a full factory exhaust line, every job is handled by the same family-run team that has worked Victoria for over 30 years.</p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {divisions.map((d) => (
        <article class="group flex flex-col overflow-hidden rounded-2xl border border-ink-100 bg-paper shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
          <div class="overflow-hidden">
            <img src={d.img} alt={d.alt} width="800" height="534" loading="lazy" class="aspect-[3/2] w-full object-cover transition duration-500 group-hover:scale-105" />
          </div>
          <div class="flex flex-1 flex-col p-7">
            <h3 class="font-display text-2xl font-700 uppercase tracking-tight text-ink-900">{d.name}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-600">{d.desc}</p>
            <ul class="mt-5 space-y-2">
              {d.points.map((p) => (
                <li class="flex items-center gap-2.5 text-sm text-ink-700">
                  <svg class="h-4 w-4 shrink-0 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                  {p}
                </li>
              ))}
            </ul>
            <a href="/services" class="mt-6 inline-flex items-center gap-1.5 text-sm font-700 text-green-700 transition group-hover:gap-2.5">
              Learn more
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Why choose us -->
  <section class="bg-paper-soft border-y border-ink-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-20">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div>
          <p class="text-sm font-700 uppercase tracking-[0.16em] text-green-600">Why O'Connor</p>
          <h2 class="mt-2 font-display text-3xl font-800 uppercase tracking-tight text-ink-900 sm:text-4xl">Trades you can rely on</h2>
          <div class="mt-8 space-y-7">
            {reasons.map((r) => (
              <div class="flex gap-4">
                <span class="mt-1 grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-green-100 text-green-700">
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                </span>
                <div>
                  <h3 class="font-700 text-ink-900">{r.title}</h3>
                  <p class="mt-1.5 text-sm leading-relaxed text-ink-600">{r.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <img src="/images/work-7.jpg" alt="Soot and debris cleared from the base of a flue" width="800" height="534" loading="lazy" class="aspect-[3/4] w-full rounded-2xl object-cover" />
          <img src="/images/work-3.jpg" alt="Inside of cleaned spiral ductwork" width="800" height="534" loading="lazy" class="mt-8 aspect-[3/4] w-full rounded-2xl object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-20">
    <div class="max-w-2xl">
      <p class="text-sm font-700 uppercase tracking-[0.16em] text-green-600">How it works</p>
      <h2 class="mt-2 font-display text-3xl font-800 uppercase tracking-tight text-ink-900 sm:text-4xl">Getting booked in is easy</h2>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {steps.map((s) => (
        <div class="rounded-2xl border border-ink-100 bg-paper-soft p-7">
          <span class="grid h-11 w-11 place-items-center rounded-full bg-green-600 font-display text-lg font-800 text-white">{s.n}</span>
          <h3 class="mt-4 font-display text-xl font-700 text-ink-900">{s.t}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-600">{s.d}</p>
        </div>
      ))}
    </div>
  </section>

  <CtaBand />
</Layout>
