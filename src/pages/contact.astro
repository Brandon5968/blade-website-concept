---
import Layout from "../layouts/Layout.astro";
import { site } from "../data/site";

const methods = [
  { label: "Phone and bookings", value: site.phone, href: site.phoneHref, icon: "M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1L6.6 10.8Z" },
  { label: "Email", value: site.email, href: `mailto:${site.email}`, icon: "M4 6h16v12H4zM4 7l8 6 8-6" },
  { label: "Postal address", value: site.postal, href: null, icon: "M3 7l9 6 9-6M3 7v10h18V7M3 7l9-4 9 4" },
  { label: "Fax", value: site.fax, href: null, icon: "M6 9V3h12v6M6 18h12v3H6zM6 14h12v4H6zM4 9h16v5H4z" },
];
---

<Layout title="Contact" description={`Contact Michael O'Connor & Son Industries. Phone ${site.phone} or email ${site.email}. Open 24 hours, 7 days, with 24 hour emergency call-out.`}>
  <section class="bg-sand border-b border-ink-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-14">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div class="animate-fade-up">
          <p class="text-sm font-700 uppercase tracking-[0.16em] text-green-700">Get in touch</p>
          <h1 class="mt-3 font-display text-4xl font-700 uppercase leading-[0.95] tracking-tight text-ink-900 sm:text-5xl">Let's get your flue sorted</h1>
          <p class="mt-5 max-w-[58ch] text-lg text-ink-800">
            Booking a sweep, after a quote, or dealing with a smoking emergency? Reach us whichever way
            suits. We are open seven days.
          </p>
        </div>
        <div class="rounded-2xl bg-green-800 p-8 text-white shadow-xl">
          <div class="font-display text-2xl font-700 uppercase tracking-tight">Open 24 hours, 7 days</div>
          <p class="mt-2 text-green-50">Call any time on</p>
          <a href={site.phoneHref} class="mt-1 inline-block font-display text-4xl font-700 tracking-tight hover:text-green-200">{site.phone}</a>
          <p class="mt-4 text-sm text-green-100">{site.emergency} for blocked flues and anything urgent.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-16 grid gap-12 lg:grid-cols-5">
    <!-- contact methods -->
    <div class="lg:col-span-2 space-y-4">
      {methods.map((m) => (
        <div class="flex items-start gap-4 rounded-2xl border border-ink-100 bg-paper p-5">
          <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-green-100 text-green-800">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
          </span>
          <div>
            <div class="text-xs font-700 uppercase tracking-wide text-ink-500">{m.label}</div>
            {m.href
              ? <a href={m.href} class="font-display text-lg font-700 text-ink-900 hover:text-green-800 transition-colors break-words">{m.value}</a>
              : <div class="font-display text-lg font-700 text-ink-900">{m.value}</div>}
          </div>
        </div>
      ))}
      <p class="px-1 text-xs text-ink-500">ABN {site.abn}.</p>
    </div>

    <!-- form -->
    <div class="lg:col-span-3">
      <div class="rounded-2xl border border-ink-100 bg-paper p-7 sm:p-9 shadow-sm">
        <h2 class="font-display text-2xl font-700 uppercase tracking-tight text-ink-900">Request a quote or booking</h2>
        <p class="mt-2 text-sm text-ink-600">Tell us a bit about the job and we will get back to you, usually the same day.</p>

        <form class="mt-7 grid gap-5 sm:grid-cols-2" action={`mailto:${site.email}`} method="post" enctype="text/plain">
          <div class="sm:col-span-1">
            <label for="name" class="block text-sm font-600 text-ink-800">Name</label>
            <input id="name" name="name" type="text" required autocomplete="name" class="mt-1.5 w-full rounded-lg border border-ink-200 bg-sand px-3.5 py-2.5 text-ink-900 outline-none transition focus:border-green-600 focus:bg-paper focus:ring-2 focus:ring-green-600/20" placeholder="Your name" />
          </div>
          <div class="sm:col-span-1">
            <label for="phone" class="block text-sm font-600 text-ink-800">Phone</label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" class="mt-1.5 w-full rounded-lg border border-ink-200 bg-sand px-3.5 py-2.5 text-ink-900 outline-none transition focus:border-green-600 focus:bg-paper focus:ring-2 focus:ring-green-600/20" placeholder="04xx xxx xxx" />
          </div>
          <div class="sm:col-span-2">
            <label for="email" class="block text-sm font-600 text-ink-800">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email" class="mt-1.5 w-full rounded-lg border border-ink-200 bg-sand px-3.5 py-2.5 text-ink-900 outline-none transition focus:border-green-600 focus:bg-paper focus:ring-2 focus:ring-green-600/20" placeholder="you@example.com" />
          </div>
          <div class="sm:col-span-2">
            <label for="service" class="block text-sm font-600 text-ink-800">Type of job</label>
            <select id="service" name="service" class="mt-1.5 w-full rounded-lg border border-ink-200 bg-sand px-3.5 py-2.5 text-ink-900 outline-none transition focus:border-green-600 focus:bg-paper focus:ring-2 focus:ring-green-600/20">
              <option>Domestic, wood heater or fireplace</option>
              <option>Commercial, kitchen canopy or oven</option>
              <option>Industrial, exhaust or ductwork</option>
              <option>Wedding sweep</option>
              <option>Something else</option>
            </select>
          </div>
          <div class="sm:col-span-2">
            <label for="message" class="block text-sm font-600 text-ink-800">Details</label>
            <textarea id="message" name="message" rows="4" class="mt-1.5 w-full rounded-lg border border-ink-200 bg-sand px-3.5 py-2.5 text-ink-900 outline-none transition focus:border-green-600 focus:bg-paper focus:ring-2 focus:ring-green-600/20" placeholder="Your suburb, the type of fire or system, and anything else we should know"></textarea>
          </div>
          <div class="sm:col-span-2">
            <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-md bg-green-700 px-6 py-3.5 font-700 text-white shadow-sm transition hover:bg-green-800 sm:w-auto">
              Send enquiry
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </button>
            <p class="mt-3 text-xs text-ink-500">Prefer to talk? Call us on <a href={site.phoneHref} class="font-600 text-green-800">{site.phone}</a>.</p>
          </div>
        </form>
      </div>
    </div>
  </section>
</Layout>
