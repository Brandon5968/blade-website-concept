---
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../data/site";

const divisions = [
  {
    id: "industrial",
    name: "Industrial Division",
    img: "/images/work-9.jpg",
    alt: "Industrial stenter and exhaust line in a Victorian textile factory",
    lead: "Heavy duty exhaust and process cleaning that keeps your plant compliant.",
    body: "We service stenters, large exhaust systems, process ovens and the ductwork that keeps industrial sites moving. Our crews are WorkSafe confined space certified and set up for the dirtiest jobs, and we give you clear reporting you can keep on file.",
    items: [
      "Industrial exhaust and extraction systems",
      "Stenter and process oven lines",
      "Large ductwork and flues",
      "Confined space entry and cleaning",
      "Scheduled maintenance programs",
    ],
  },
  {
    id: "commercial",
    name: "Commercial Division",
    img: "/images/work-6.jpg",
    alt: "Commercial wood-fired pizza oven serviced by Michael O'Connor & Son",
    lead: "Fire safe kitchens and ovens, cleaned around your trading hours.",
    body: "Grease in kitchen canopies and flues is one of the biggest fire risks in any commercial kitchen. We clean pizza ovens, bakery ovens, canopies and exhaust ducting to fire safety standard, and we provide the paperwork your insurer and council expect.",
    items: [
      "Commercial kitchen canopy cleaning",
      "Exhaust flue and ducting degrease",
      "Pizza, bakery and wood-fired ovens",
      "Fire safety reporting",
      "After hours bookings available",
    ],
  },
  {
    id: "domestic",
    name: "Domestic Division",
    img: "/images/work-2.jpg",
    alt: "Clean domestic flue interior after a sweep",
    lead: "Clean, safe home heating without the mess.",
    body: "A swept chimney is a safe chimney. We clean wood heaters, open fires and flex-duct heating, which keeps soot build up, blockages and chimney fires at bay. We lay drop sheets, keep the dust contained and give the flue a quick safety check every visit.",
    items: [
      "Wood heaters and combustion fires",
      "Open fires and masonry flues",
      "Flex-duct heating cleaning",
      "Cowl, cap and flue checks",
      "Clean, no mess service",
    ],
  },
];
---

<Layout title="Services" description="Industrial, commercial and domestic chimney sweeping across Victoria, including exhaust systems, kitchen canopies and wood heaters. Fully certified and insured.">
  <!-- header -->
  <section class="bg-paper-soft border-b border-ink-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
      <div class="max-w-2xl animate-fade-up">
        <p class="text-sm font-700 uppercase tracking-[0.16em] text-green-600">Our services</p>
        <h1 class="mt-3 font-display text-4xl font-800 uppercase leading-tight tracking-tight text-ink-900 sm:text-5xl">Sweeping done properly, at every scale</h1>
        <p class="mt-5 text-lg text-ink-600">From a single home fireplace to a full industrial exhaust line, we clean, check and certify the lot. {site.hours}.</p>
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        {divisions.map((d) => (
          <a href={`#${d.id}`} class="rounded-full border border-ink-200 bg-paper px-4 py-2 text-sm font-600 text-ink-700 transition hover:border-green-300 hover:text-green-700">{d.name}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- division detail -->
  {divisions.map((d, i) => (
    <section id={d.id} class:list={["scroll-mt-20", i % 2 === 1 ? "bg-paper-soft border-y border-ink-100" : ""]}>
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 grid gap-10 lg:grid-cols-2 lg:items-center">
        <div class:list={[i % 2 === 1 ? "lg:order-2" : ""]}>
          <span class="inline-block rounded-full bg-green-100 px-3 py-1 text-xs font-700 uppercase tracking-wide text-green-800">{`0${i + 1}`} Division</span>
          <h2 class="mt-4 font-display text-3xl font-800 uppercase tracking-tight text-ink-900 sm:text-4xl">{d.name}</h2>
          <p class="mt-3 text-lg font-600 text-green-700">{d.lead}</p>
          <p class="mt-4 leading-relaxed text-ink-600">{d.body}</p>
          <ul class="mt-6 grid gap-2.5 sm:grid-cols-2">
            {d.items.map((it) => (
              <li class="flex items-center gap-2.5 text-sm text-ink-700">
                <svg class="h-4 w-4 shrink-0 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                {it}
              </li>
            ))}
          </ul>
          <a href={site.phoneHref} class="mt-7 inline-flex items-center gap-2 rounded-md bg-green-600 px-5 py-3 text-sm font-700 text-white transition hover:bg-green-700">
            Book this service
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
        <div class:list={[i % 2 === 1 ? "lg:order-1" : ""]}>
          <div class="overflow-hidden rounded-2xl border border-ink-100 shadow-lg shadow-ink-900/5">
            <img src={d.img} alt={d.alt} width="1000" height="667" loading="lazy" class="aspect-[3/2] w-full object-cover" />
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- accreditations -->
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-16">
    <div class="rounded-2xl border border-ink-100 bg-paper-soft px-6 py-12 sm:px-12">
      <h2 class="font-display text-2xl font-800 uppercase tracking-tight text-ink-900 sm:text-3xl">Certified, insured and safety trained</h2>
      <p class="mt-3 max-w-2xl text-ink-600">Every job, from a home heater to an industrial line, is carried out to the relevant safety standards by trained, certified crews.</p>
      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        {site.accreditations.map((a) => (
          <div class="rounded-xl border border-ink-100 bg-paper p-5">
            <svg class="h-6 w-6 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M9 12l2 2 4-4M12 3l8 4v5c0 5-3.4 8-8 9-4.6-1-8-4-8-9V7l8-4Z"/></svg>
            <p class="mt-3 text-sm font-600 text-ink-800">{a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading="Not sure which division you need?" sub="Give us a call and we will sort out the right team for the job, whether it is a home heater, a commercial kitchen or an industrial line." />
</Layout>
