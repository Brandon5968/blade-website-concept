---
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";
import Credentials from "../components/Credentials.astro";
import { site } from "../data/site";

const divisions = [
  {
    id: "industrial",
    name: "Industrial Division",
    area: "Australia-wide",
    img: "/images/work-9.jpg",
    alt: "Industrial stenter and exhaust line in a Victorian textile factory",
    lead: "Heavy exhaust and ovenline cleaning that keeps your plant compliant.",
    body: "We clean stenters, large exhaust systems, process ovens and the ductwork that keeps industrial sites moving. We have specialist experience with tin-plate printing and manufacturing equipment, and we work with German and European ovenline manufacturers. Our crews are WorkSafe confined space certified and we give you clear reporting for your records.",
    items: [
      "Industrial exhaust and extraction systems",
      "Stenter and process ovenlines",
      "Tin-plate printing and manufacturing lines",
      "German and European ovenline equipment",
      "Confined space entry and cleaning",
      "Scheduled maintenance programs",
    ],
  },
  {
    id: "commercial",
    name: "Commercial Division",
    area: "Victoria-wide",
    img: "/images/work-6.jpg",
    alt: "Commercial wood-fired pizza oven serviced by Michael O'Connor & Son",
    lead: "Fire-safe kitchens and ovens, cleaned around your trading hours.",
    body: "Grease in kitchen canopies and flues is one of the biggest fire risks in any commercial kitchen. We clean pizza ovens, bakery ovens, canopies and exhaust ducting to fire safety standard, and we provide the documentation your insurer and council expect. We also run ongoing maintenance programs for hotel groups and hospitality venues.",
    items: [
      "Commercial kitchen canopy cleaning",
      "Exhaust flue and ducting degrease",
      "Pizza, bakery and wood-fired ovens",
      "Fire safety reporting",
      "Maintenance programs for hotels and hospitality",
      "After-hours bookings available",
    ],
  },
  {
    id: "domestic",
    name: "Domestic Division",
    area: "Victoria-wide",
    img: "/images/work-2.jpg",
    alt: "Clean domestic flue interior after a sweep",
    lead: "Clean, safe home heating without the mess.",
    body: "A swept chimney is a safe chimney. We clean wood heaters, open fires and flex-duct heating, which keeps soot build-up, blockages and chimney fires at bay. We also clear beehives and possums from chimneys, fit possum grids, and supply and install cowls and dampers. Drop sheets go down and the dust stays contained on every job.",
    items: [
      "Wood heaters and combustion fires",
      "Open fires and masonry flues",
      "Flex-duct heating cleaning",
      "Beehive and possum removal",
      "Possum grids fitted",
      "Cowl and damper supply and install",
    ],
  },
];
---

<Layout title="Services" description="Industrial, commercial and domestic chimney sweeping. Exhaust systems and ovenlines Australia-wide; kitchens and home heaters across Victoria. Fully certified and insured.">
  <!-- header -->
  <section class="bg-sand border-b border-ink-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-14">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div class="animate-fade-up">
          <p class="text-sm font-700 uppercase tracking-[0.16em] text-green-700">Our services</p>
          <h1 class="mt-3 font-display text-4xl font-700 uppercase leading-[0.95] tracking-tight text-ink-900 sm:text-5xl">Sweeping done properly, at every scale</h1>
          <p class="mt-5 max-w-[60ch] text-lg text-ink-800">
            From a single home fireplace to a full industrial exhaust line, we clean, check and
            certify the lot. Domestic and commercial across Victoria, industrial across Australia.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            {divisions.map((d) => (
              <a href={`#${d.id}`} class="rounded-full border border-ink-300 bg-paper px-4 py-2 text-sm font-600 text-ink-800 transition hover:border-green-400 hover:text-green-800">{d.name.replace(" Division", "")}</a>
            ))}
          </div>
        </div>
        <div class="overflow-hidden rounded-2xl border border-ink-200 shadow-xl shadow-ink-900/10">
          <img src="/images/work-8.jpg" alt="Inside a cleaned industrial exhaust housing" width="1000" height="667" class="aspect-[3/2] w-full object-cover" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- division detail -->
  {divisions.map((d, i) => (
    <section id={d.id} class:list={["scroll-mt-20", i % 2 === 1 ? "bg-paper border-y border-ink-100" : ""]}>
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 grid gap-10 lg:grid-cols-2 lg:items-center">
        <div class:list={[i % 2 === 1 ? "lg:order-2" : ""]}>
          <div class="flex flex-wrap items-center gap-3">
            <span class="inline-block rounded-full bg-green-100 px-3 py-1 text-xs font-700 uppercase tracking-wide text-green-800">{`0${i + 1}`} Division</span>
            <span class="inline-flex items-center gap-1.5 text-xs font-600 text-ink-600">
              <svg class="h-4 w-4 text-green-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
              {d.area}
            </span>
          </div>
          <h2 class="mt-4 font-display text-3xl font-700 uppercase tracking-tight text-ink-900 sm:text-4xl">{d.name}</h2>
          <p class="mt-3 text-lg font-600 text-green-800">{d.lead}</p>
          <p class="mt-4 max-w-[64ch] leading-relaxed text-ink-800">{d.body}</p>
          <ul class="mt-6 grid gap-2.5 sm:grid-cols-2">
            {d.items.map((it) => (
              <li class="flex items-center gap-2.5 text-sm text-ink-800">
                <svg class="h-4 w-4 shrink-0 text-green-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                {it}
              </li>
            ))}
          </ul>
          <a href={site.phoneHref} class="mt-7 inline-flex items-center gap-2 rounded-md bg-green-700 px-5 py-3 text-sm font-700 text-white transition hover:bg-green-800">
            Book this service
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
        <div class:list={[i % 2 === 1 ? "lg:order-1" : ""]}>
          <div class="overflow-hidden rounded-2xl border border-ink-100 shadow-lg shadow-ink-900/5">
            <img src={d.img} alt={d.alt} width="1000" height="667" loading="lazy" class="aspect-[3/2] w-full object-cover" />
          </div>
        </div>
      </div>
    </section>
  ))}

  <Credentials />

  <CtaBand heading="Not sure which division you need?" sub="Give us a call and we will sort out the right team for the job, whether it is a home heater, a commercial kitchen or an industrial line." />
</Layout>
